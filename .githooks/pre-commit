#!/bin/bash
# Pre-commit hook: JS ESLint + 语法检查 + Python 语法检查

set -e

echo "🔍 Running pre-commit checks..."

# 1. ESLint（如果可用）
if [ -f "frontend/node_modules/.bin/eslint" ]; then
    echo "  Running ESLint..."
    cd frontend
    ESLINT_OUTPUT=$(npx eslint js/ 2>&1 || true)
    ERRORS=$(echo "$ESLINT_OUTPUT" | grep -c " error " || true)
    if [ "$ERRORS" -gt 0 ]; then
        echo "❌ ESLint found $ERRORS error(s):"
        echo "$ESLINT_OUTPUT" | grep " error "
        cd ..
        exit 1
    fi
    cd ..
    echo "  ✅ ESLint passed"
fi

# 2. JS 语法检查（fallback）
JS_ERRORS=0
for f in frontend/js/app.js frontend/js/components.js frontend/js/pages/*.js; do
    if [ -f "$f" ]; then
        if ! node --check "$f" 2>/dev/null; then
            echo "❌ JS syntax error: $f"
            node --check "$f" 2>&1 | head -3
            JS_ERRORS=$((JS_ERRORS + 1))
        fi
    fi
done

# 3. Python 语法检查
PY_ERRORS=0
for f in app.py backend/*.py backend/routers/*.py backend/services/*.py; do
    if [ -f "$f" ]; then
        if ! python3 -m py_compile "$f" 2>/dev/null; then
            echo "❌ Python syntax error: $f"
            PY_ERRORS=$((PY_ERRORS + 1))
        fi
    fi
done

# 4. 结果
TOTAL=$((JS_ERRORS + PY_ERRORS))
if [ $TOTAL -gt 0 ]; then
    echo ""
    echo "❌ Pre-commit check failed: $JS_ERRORS JS error(s), $PY_ERRORS Python error(s)"
    exit 1
fi

echo "✅ Pre-commit checks passed"
